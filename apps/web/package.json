    "@jobfindeer/ui": "workspace:*",
    "@jobfindeer/validators": "workspace:*",
    "@sentry/nextjs": "^10.48.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
