{
  "name": "@jobfindeer/pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "dotenv -e ../../.env -- node --import tsx/esm src/index.ts",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@jobfindeer/eslint-config": "workspace:*",
    "@jobfindeer/prettier-config": "workspace:*",
    "@jobfindeer/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@jobfindeer/prettier-config",
  "dependencies": {
    "@jobfindeer/db": "workspace:*",
    "@jobfindeer/queue": "workspace:*",
    "@jobfindeer/validators": "workspace:*",
    "bullmq": "^5.73.3",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.44.7",
    "robots-parser": "^3.0.1",
    "tsx": "^4.21.0"
  }
}
