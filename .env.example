# Notion
NOTION_API_KEY=               # Integration token Notion
NOTION_DATABASE_ID=           # ID de la database Notion Job Tracker

# France Travail API (optionnel)
FRANCE_TRAVAIL_CLIENT_ID=     # Obtenu sur francetravail.io/data
FRANCE_TRAVAIL_CLIENT_SECRET=

# Gmail API (pour parser les alertes LinkedIn)
GMAIL_CLIENT_ID=              # OAuth 2.0 Client ID (Google Cloud Console)
GMAIL_CLIENT_SECRET=          # OAuth 2.0 Client Secret
GMAIL_REFRESH_TOKEN=          # Obtenu via: npx tsx scripts/gmail-auth.ts
